---
import { ts, DEFAULT_LOCALE, type Locale } from "../../i18n";

interface Props {
  locale: Locale;
  currentPage: string;
}

const { locale, currentPage } = Astro.props;
const base = import.meta.env.BASE_URL;

function docsHref(page: string, hash?: string): string {
  const pageSuffix = page ? `${page}/` : "";
  const localePrefix = locale === DEFAULT_LOCALE ? "" : `${locale}/`;
  return `${base}${localePrefix}docs/${pageSuffix}${hash ? "#" + hash : ""}`;
}

const sidebarSections = [
  {
    id: "overview",
    label: ts(locale, "docsSidebarOverview"),
    page: "",
  },
  {
    id: "cli",
    label: ts(locale, "docsSidebarCli"),
    page: "cli",
    children: [
      { id: "cli-run", label: "ccpoke" },
      { id: "cli-setup", label: "setup" },
      { id: "cli-project", label: "project" },
      { id: "cli-channel", label: "channel" },
      { id: "cli-update", label: "update" },
      { id: "cli-uninstall", label: "uninstall" },
      { id: "cli-help", label: "help" },
    ],
  },
  {
    id: "telegram",
    label: ts(locale, "docsSidebarTelegram"),
    page: "telegram",
    children: [
      { id: "tg-commands", label: ts(locale, "docsSidebarTgCommands") },
      { id: "tg-notifications", label: ts(locale, "docsSidebarTgNotifications") },
      { id: "tg-chat", label: ts(locale, "docsSidebarTgChat") },
      { id: "tg-permissions", label: ts(locale, "docsSidebarTgPermissions") },
      { id: "tg-questions", label: ts(locale, "docsSidebarTgQuestions") },
    ],
  },
  {
    id: "discord",
    label: ts(locale, "docsSidebarDiscord"),
    page: "discord",
    children: [
      { id: "dc-commands", label: ts(locale, "docsSidebarDcCommands") },
      { id: "dc-notifications", label: ts(locale, "docsSidebarDcNotifications") },
      { id: "dc-chat", label: ts(locale, "docsSidebarDcChat") },
      { id: "dc-permissions", label: ts(locale, "docsSidebarDcPermissions") },
      { id: "dc-questions", label: ts(locale, "docsSidebarDcQuestions") },
    ],
  },
  {
    id: "slack",
    label: ts(locale, "docsSidebarSlack"),
    page: "slack",
    children: [
      { id: "slk-notifications", label: ts(locale, "docsSidebarSlkNotifications") },
    ],
  },
  {
    id: "config",
    label: ts(locale, "docsSidebarConfig"),
    page: "config",
  },
];
---

<aside class="docs-sidebar" id="docsSidebar">
  <nav class="docs-sidebar__nav">
    {sidebarSections.map((section) => {
      const isActivePage = section.page === currentPage;
      const sectionHref = docsHref(section.page);

      return (
        <div class="docs-sidebar__group">
          <a
            href={sectionHref}
            class:list={[
              "docs-sidebar__link",
              { "docs-sidebar__link--parent": !!section.children },
              { "docs-sidebar__link--parent-active": isActivePage && !!section.children },
              { "docs-sidebar__link--top": !section.children },
              { "docs-sidebar__link--active": isActivePage && !section.children },
            ]}
            data-sidebar-id={section.id}
          >
            {section.label}
          </a>
          {section.children && (
            <div class="docs-sidebar__children">
              {section.children.map((child) => (
                <a
                  href={isActivePage ? `#${child.id}` : docsHref(section.page, child.id)}
                  class="docs-sidebar__link docs-sidebar__link--child"
                  data-sidebar-id={child.id}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      );
    })}
  </nav>
</aside>

<script>
  const HEADER_HEIGHT = 72;
  const SCROLL_BUFFER = 20;

  const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>("[data-sidebar-id]");
  const trackedIds = new Set<string>();
  const sectionEls: HTMLElement[] = [];

  sidebarLinks.forEach((a) => {
    const id = a.dataset.sidebarId!;
    const el = document.getElementById(id);
    if (el) {
      trackedIds.add(id);
      sectionEls.push(el);
    }
  });

  function updateActiveSidebar() {
    const atBottom = (window.scrollY + window.innerHeight) >= (document.documentElement.scrollHeight - 10);

    if (atBottom && sectionEls.length > 0) {
      const lastId = sectionEls[sectionEls.length - 1].id;
      sidebarLinks.forEach((a) => {
        const id = a.dataset.sidebarId!;
        if (trackedIds.has(id)) {
          a.classList.toggle("docs-sidebar__link--active", id === lastId);
        }
      });
      return;
    }

    let activeId: string | null = null;

    for (const el of sectionEls) {
      const rect = el.getBoundingClientRect();
      if (rect.top <= HEADER_HEIGHT + SCROLL_BUFFER) {
        activeId = el.id;
      }
    }

    if (!activeId && sectionEls.length > 0) {
      activeId = sectionEls[0].id;
    }

    if (!activeId) return;

    sidebarLinks.forEach((a) => {
      const id = a.dataset.sidebarId!;
      if (trackedIds.has(id)) {
        a.classList.toggle("docs-sidebar__link--active", id === activeId);
      }
    });
  }

  let ticking = false;
  document.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        updateActiveSidebar();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  updateActiveSidebar();
</script>
