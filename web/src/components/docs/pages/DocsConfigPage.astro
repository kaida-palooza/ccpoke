---
import { ts, DEFAULT_LOCALE, type Locale } from "../../../i18n";
import DocsPagination from "../DocsPagination.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;
const breadcrumbHref = locale === DEFAULT_LOCALE ? `${base}docs/` : `${base}${locale}/docs/`;
---

<article class="docs-content">
  <nav class="docs-breadcrumb">
    <a href={breadcrumbHref}>Docs</a>
    <span class="docs-breadcrumb__sep">›</span>
    {ts(locale, "docsConfigTitle")}
  </nav>
  <section class="docs-content__section">
    <h1>{ts(locale, "docsConfigTitle")}</h1>
    <p>{ts(locale, "docsConfigDesc")}</p>
    <p class="docs-content__config-file">{ts(locale, "docsConfigFileLocation")}</p>

    <div class="docs-config-table-wrap">
      <table class="docs-config-table">
        <thead>
          <tr>
            <th>{ts(locale, "docsConfigKeyHeader")}</th>
            <th>{ts(locale, "docsConfigTypeHeader")}</th>
            <th>{ts(locale, "docsConfigDefaultHeader")}</th>
            <th>{ts(locale, "docsConfigDescHeader")}</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>channel</td><td>string</td><td>"telegram"</td><td>{ts(locale, "docsConfigChannel")}</td></tr>
          <tr><td>telegram_bot_token</td><td>string</td><td>—</td><td>{ts(locale, "docsConfigBotToken")}</td></tr>
          <tr><td>user_id</td><td>integer</td><td>—</td><td>{ts(locale, "docsConfigUserId")}</td></tr>
          <tr><td>discord_bot_token</td><td>string</td><td>—</td><td>{ts(locale, "docsConfigDiscordBotToken")}</td></tr>
          <tr><td>discord_user_id</td><td>string</td><td>—</td><td>{ts(locale, "docsConfigDiscordUserId")}</td></tr>
          <tr><td>slack_bot_token</td><td>string</td><td>—</td><td>{ts(locale, "docsConfigSlackBotToken")}</td></tr>
          <tr><td>slack_channel_id</td><td>string</td><td>—</td><td>{ts(locale, "docsConfigSlackChannelId")}</td></tr>
          <tr><td>hook_port</td><td>integer</td><td>9377</td><td>{ts(locale, "docsConfigHookPort")}</td></tr>
          <tr><td>hook_secret</td><td>string</td><td>auto</td><td>{ts(locale, "docsConfigHookSecret")}</td></tr>
          <tr><td>locale</td><td>string</td><td>"en"</td><td>{ts(locale, "docsConfigLocale")}</td></tr>
          <tr><td>agents</td><td>string[]</td><td>["claude-code"]</td><td>{ts(locale, "docsConfigAgents")}</td></tr>
          <tr><td>projects</td><td>array</td><td>[]</td><td>{ts(locale, "docsConfigProjects")}</td></tr>
        </tbody>
      </table>
    </div>

    <h3 class="docs-content__example-title">{ts(locale, "docsConfigExampleTitle")}</h3>
    <pre class="cmd-block__terminal">{ts(locale, "docsConfigExample")}</pre>

    <p class="docs-tip">
      <svg class="docs-tip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
      <span>{ts(locale, "docsConfigTip")}</span>
    </p>
  </section>

  <DocsPagination
    locale={locale}
    prev={{ page: "slack", labelKey: "docsSidebarSlack" }}
  />
</article>

<style>
  .docs-content__config-file {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .docs-content__example-title {
    margin-top: 1.5rem;
  }
</style>
