---
import { ts, DEFAULT_LOCALE, type Locale } from "../../../i18n";
import CommandBlock from "../CommandBlock.astro";
import DocsPagination from "../DocsPagination.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL;
const breadcrumbHref = locale === DEFAULT_LOCALE ? `${base}docs/` : `${base}${locale}/docs/`;
---

<article class="docs-content">
  <nav class="docs-breadcrumb">
    <a href={breadcrumbHref}>Docs</a>
    <span class="docs-breadcrumb__sep">›</span>
    {ts(locale, "docsCliTitle")}
  </nav>
  <section class="docs-content__section">
    <h1>{ts(locale, "docsCliTitle")}</h1>
    <p>{ts(locale, "docsCliDesc")}</p>

    <CommandBlock
      sectionId="cli-run"
      command="ccpoke"
      description={ts(locale, "docsCliRunDesc")}
      whenToUse={ts(locale, "docsCliRunWhen")}
      terminal={ts(locale, "docsCliRunTerm")}
    />
    <CommandBlock
      sectionId="cli-setup"
      command="ccpoke setup"
      description={ts(locale, "docsCliSetupDesc")}
      whenToUse={ts(locale, "docsCliSetupWhen")}
      terminal={ts(locale, "docsCliSetupTerm")}
    />
    <CommandBlock
      sectionId="cli-project"
      command="ccpoke project"
      description={ts(locale, "docsCliProjectDesc")}
      whenToUse={ts(locale, "docsCliProjectWhen")}
      terminal={ts(locale, "docsCliProjectTerm")}
    />
    <CommandBlock
      sectionId="cli-channel"
      command="ccpoke channel"
      description={ts(locale, "docsCliChannelDesc")}
      whenToUse={ts(locale, "docsCliChannelWhen")}
      terminal={ts(locale, "docsCliChannelTerm")}
    />
    <CommandBlock
      sectionId="cli-update"
      command="ccpoke update"
      description={ts(locale, "docsCliUpdateDesc")}
      whenToUse={ts(locale, "docsCliUpdateWhen")}
      terminal={ts(locale, "docsCliUpdateTerm")}
    />
    <CommandBlock
      sectionId="cli-uninstall"
      command="ccpoke uninstall"
      description={ts(locale, "docsCliUninstallDesc")}
      whenToUse={ts(locale, "docsCliUninstallWhen")}
      terminal={ts(locale, "docsCliUninstallTerm")}
    />
    <CommandBlock
      sectionId="cli-help"
      command="ccpoke help"
      description={ts(locale, "docsCliHelpDesc")}
      whenToUse={ts(locale, "docsCliHelpWhen")}
      terminal={ts(locale, "docsCliHelpTerm")}
    />
  </section>

  <DocsPagination
    locale={locale}
    prev={{ page: "", labelKey: "docsSidebarOverview" }}
    next={{ page: "telegram", labelKey: "docsSidebarTelegram" }}
  />
</article>
